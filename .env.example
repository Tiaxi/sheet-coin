# Required
SHEET_COIN_AUTH_USERNAME=your_username
SHEET_COIN_AUTH_PASSWORD=your_password

# Optional (defaults shown)
SHEET_COIN_PORT=19877
SHEET_COIN_POLLING_INTERVAL=45
SHEET_COIN_API_TIMEOUT=60
SHEET_COIN_LOG_LEVEL=INFO

# Optional: Timezone for log timestamps (default: UTC in Docker)
# TZ=Europe/Helsinki
